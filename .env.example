# Copy this file to `.env` and fill in the keys you have.
# Every key can ALSO be set from the app's Settings UI, where it's stored under your
# vault root (never committed). Nothing here is required just to browse the demo vault
# in "dry" mode, but the live reader and the Learn builder need keys (see below).

# --- Reader engine (Mercury / Inception) ---
# The streaming reader runs on Mercury, a text-diffusion model. Without this key the
# reader falls back to a free "dry" stitch mode. Get a key at https://inceptionlabs.ai
INCEPTION_API_KEY=

# --- Learn / ingest pipeline ---
# Building a vault (Learn tab, or `cli.py ingest`/`research`) needs an LLM. Anthropic
# Claude is the default; or configure any OpenAI-compatible provider in Settings instead.
ANTHROPIC_API_KEY=

# --- Web research (optional; only used by `cli.py research`) ---
# Pick one provider: tavily | brave | jina
COMPENDIUM_SEARCH_PROVIDER=
COMPENDIUM_SEARCH_API_KEY=
# Jina also serves as a page-fetch fallback; set its key to enable research via Jina:
JINA_API_KEY=

# --- Optional overrides ---
# DWELL_VAULT_ROOT=       # where vaults live (default: the repo's ./vaults)
# DWELL_HOST=127.0.0.1
# DWELL_PORT=8000
